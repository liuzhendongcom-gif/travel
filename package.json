{
  "name": "travel-reimbursement",
  "version": "1.3.0",
  "description": "差旅报销整理工具",
  "main": "src/main/index.js",
  "scripts": {
    "build:css": "tailwindcss -i src/renderer/input.css -o src/renderer/tw.css --minify && cp src/renderer/tw.css src/web/renderer/tw.css",
    "watch:css": "tailwindcss -i src/renderer/input.css -o src/renderer/tw.css --watch",
    "start": "npm run build:css && electron .",
    "build:mac": "npm run build:css && electron-builder --mac dmg --arm64",
    "build:win": "npm run build:css && electron-builder --win",
    "build:all": "npm run build:css && electron-builder --mac dmg --arm64 --win",
    "start:web": "node src/web/server.js",
    "clean:dist": "rm -rf dist/mac dist/mac-arm64 dist/release-* && rm -f dist/*.blockmap dist/builder-debug.yml dist/*.zip"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "archiver": "^6.0.1",
    "xlsx": "^0.18.5",
    "express": "^5.2.1",
    "mammoth": "^1.7.0",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^7.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/forms": "^0.5.11",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "tailwindcss": "^4.3.0"
  },
  "build": {
    "appId": "com.company.travel-reimbursement",
    "productName": "差旅报销助手1.3",
    "compression": "maximum",
    "asar": true,
    "directories": {
      "output": "dist/release-${version}"
    },
    "files": [
      "src/main/**/*",
      "src/preload.js",
      "src/preload-setup.js",
      "src/renderer/**/*",
      "assets/**/*",
      "!src/web/**/*",
      "!src/web-cloud/**/*",
      "!node_modules/tesseract.js/**/*",
      "!node_modules/tesseract.js-core/**/*",
      "!node_modules/pdf-parse/**/*",
      "!node_modules/exceljs/**/*",
      "!node_modules/express/**/*",
      "!node_modules/multer/**/*",
      "!node_modules/ws/**/*",
      "!node_modules/body-parser/**/*",
      "!node_modules/type-is/**/*",
      "!node_modules/accepts/**/*",
      "!node_modules/send/**/*",
      "!node_modules/serve-static/**/*",
      "!node_modules/mime/**/*",
      "!node_modules/**/*.map",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/README*",
      "!node_modules/**/test/**/*",
      "!node_modules/**/tests/**/*",
      "!node_modules/**/spec/**/*",
      "!node_modules/**/examples/**/*",
      "!node_modules/**/docs/**/*",
      "!node_modules/xlsx/dist/cpexcel.full.mjs",
      "!node_modules/xlsx/dist/xlsx.core.min.js",
      "!node_modules/xlsx/dist/xlsx.core.min.map",
      "!node_modules/xlsx/dist/xlsx.extendscript.js",
      "!node_modules/xlsx/dist/xlsx.full.min.js",
      "!node_modules/xlsx/dist/xlsx.full.min.map",
      "!node_modules/xlsx/dist/xlsx.mini.min.js",
      "!node_modules/xlsx/dist/xlsx.mini.min.map",
      "!node_modules/xlsx/dist/xlsx.zahl.js",
      "!node_modules/xlsx/dist/xlsx.zahl.mjs",
      "!node_modules/xlsx/dist/shim.min.js",
      "!node_modules/xlsx/xlsx.mjs",
      "!node_modules/xlsx/formats.png",
      "!node_modules/xlsx/legend.png",
      "!node_modules/xlsx/bower.json",
      "!node_modules/mammoth/mammoth.browser.js",
      "!node_modules/mammoth/mammoth.browser.min.js",
      "!node_modules/raw-body/**/*",
      "!node_modules/mime-db/**/*",
      "!node_modules/mime-types/**/*",
      "!node_modules/http-errors/**/*",
      "!node_modules/statuses/**/*",
      "!node_modules/depd/**/*",
      "!node_modules/bytes/**/*",
      "!node_modules/unpipe/**/*",
      "!node_modules/iconv-lite/**/*",
      "!node_modules/setprototypeof/**/*",
      "!node_modules/toidentifier/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/ocr_tool",
        "to": "bin/ocr_tool"
      },
      {
        "from": "assets/使用说明_Mac.txt",
        "to": "使用说明_Mac.txt"
      },
      {
        "from": "assets/使用说明_Windows.txt",
        "to": "使用说明_Windows.txt"
      }
    ],
    "mac": {
      "icon": "assets/PFW.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.business",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "差旅报销助手1.3",
      "background": "assets/dmg-background.tiff",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 340,
          "type": "file",
          "path": "assets/一键修复Mac安全拦截.command"
        }
      ]
    },
    "win": {
      "icon": "assets/PFW.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "差旅报销助手1.3-安装程序.exe",
      "shortcutName": "差旅报销助手1.3",
      "uninstallDisplayName": "差旅报销助手1.3",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
